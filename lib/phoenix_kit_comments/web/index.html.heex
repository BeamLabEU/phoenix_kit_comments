<div class="container flex flex-col mx-auto px-4 py-6">
  <.comment_markdown_styles />
  <%!-- Title + subtitle now live in the top navbar (set via the page_title /
       page_subtitle assigns); the Settings shortcut lives in the filter
       toolbar below so it doesn't claim a row of its own. --%>

  <%!-- Statistics --%>
  <div class="grid grid-cols-2 md:grid-cols-6 gap-4 mb-6">
    <div class="stat bg-base-200 rounded-xl">
      <div class="stat-title">{gettext("Total")}</div>
      <div class="stat-value text-primary text-2xl">{@stats.total}</div>
    </div>
    <div class="stat bg-base-200 rounded-xl">
      <div class="stat-title">{gettext("Published")}</div>
      <div class="stat-value text-success text-2xl">{@stats.published}</div>
    </div>
    <div class="stat bg-base-200 rounded-xl">
      <div class="stat-title">{gettext("Pending")}</div>
      <div class="stat-value text-warning text-2xl">{@stats.pending}</div>
    </div>
    <div class="stat bg-base-200 rounded-xl">
      <div class="stat-title">{gettext("Hidden")}</div>
      <div class="stat-value text-info text-2xl">{@stats.hidden}</div>
    </div>
    <div class="stat bg-base-200 rounded-xl">
      <div class="stat-title">{gettext("Deleted")}</div>
      <div class="stat-value text-error text-2xl">{@stats.deleted}</div>
    </div>
    <%!-- Actions tile — sits with the counts instead of claiming a row of its
         own. Settings is the first action; more will be added here later. --%>
    <div class="stat bg-base-200 rounded-xl">
      <div class="stat-title">{gettext("Actions")}</div>
      <div class="flex flex-wrap items-center gap-1.5 mt-1">
        <.link
          navigate={Routes.path("/admin/settings/comments")}
          class="btn btn-sm btn-ghost gap-1.5"
        >
          <.icon name="hero-cog-6-tooth" class="w-4 h-4" /> {gettext("Settings")}
        </.link>
      </div>
    </div>
  </div>

  <%!-- Filters: Desktop --%>
  <div class="hidden md:block bg-base-200 rounded-lg p-4 mb-6">
    <.form for={%{}} phx-change="filter" class="flex gap-4 items-end">
      <div class="form-control flex-1">
        <label class="label"><span class="label-text">{gettext("Search")}</span></label>
        <div class="relative">
          <input
            type="text"
            name="search[query]"
            value={@search}
            placeholder={gettext("Search comment content...")}
            class="input input-bordered input-sm w-full pr-8"
            phx-debounce="300"
          />
          <button
            :if={@search != ""}
            type="button"
            phx-click="clear_search"
            class="absolute right-1.5 top-1/2 -translate-y-1/2 btn btn-ghost btn-xs btn-circle"
            title={gettext("Clear search")}
          >
            <.icon name="hero-x-mark" class="w-3.5 h-3.5" />
          </button>
        </div>
      </div>

      <div class="form-control w-40">
        <label class="label"><span class="label-text">{gettext("Resource Type")}</span></label>
        <label class="select select-sm w-full">
          <select name="filter[resource_type]">
            <option value="">{gettext("All Types")}</option>
            <%= for rt <- @resource_types do %>
              <option value={rt} selected={@filter_resource_type == rt}>
                {String.capitalize(rt)}
              </option>
            <% end %>
          </select>
        </label>
      </div>

      <div class="form-control w-36">
        <label class="label"><span class="label-text">{gettext("Status")}</span></label>
        <label class="select select-sm w-full">
          <select name="filter[status]">
            <option value="">{gettext("All Statuses")}</option>
            <option value="published" selected={@filter_status == "published"}>
              {gettext("Published")}
            </option>
            <option value="pending" selected={@filter_status == "pending"}>
              {gettext("Pending")}
            </option>
            <option value="hidden" selected={@filter_status == "hidden"}>
              {gettext("Hidden")}
            </option>
            <option value="deleted" selected={@filter_status == "deleted"}>
              {gettext("Deleted")}
            </option>
          </select>
        </label>
      </div>

      <button type="button" phx-click="clear_filters" class="btn btn-ghost btn-sm shrink-0">
        {gettext("Clear")}
      </button>
    </.form>
  </div>

  <%!-- Filters: Mobile --%>
  <div class="md:hidden bg-base-200 rounded-lg p-4 mb-6">
    <.form for={%{}} phx-change="filter" class="space-y-3">
      <div class="form-control">
        <label class="label"><span class="label-text">{gettext("Search")}</span></label>
        <div class="relative">
          <input
            type="text"
            name="search[query]"
            value={@search}
            placeholder={gettext("Search comment content...")}
            class="input input-bordered input-sm w-full pr-8"
            phx-debounce="300"
          />
          <button
            :if={@search != ""}
            type="button"
            phx-click="clear_search"
            class="absolute right-1.5 top-1/2 -translate-y-1/2 btn btn-ghost btn-xs btn-circle"
            title={gettext("Clear search")}
          >
            <.icon name="hero-x-mark" class="w-3.5 h-3.5" />
          </button>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div class="form-control">
          <label class="label"><span class="label-text">{gettext("Resource Type")}</span></label>
          <label class="select select-sm w-full">
            <select name="filter[resource_type]">
              <option value="">{gettext("All Types")}</option>
              <%= for rt <- @resource_types do %>
                <option value={rt} selected={@filter_resource_type == rt}>
                  {String.capitalize(rt)}
                </option>
              <% end %>
            </select>
          </label>
        </div>

        <div class="form-control">
          <label class="label"><span class="label-text">{gettext("Status")}</span></label>
          <label class="select select-sm w-full">
            <select name="filter[status]">
              <option value="">{gettext("All Statuses")}</option>
              <option value="published" selected={@filter_status == "published"}>
                {gettext("Published")}
              </option>
              <option value="pending" selected={@filter_status == "pending"}>
                {gettext("Pending")}
              </option>
              <option value="hidden" selected={@filter_status == "hidden"}>
                {gettext("Hidden")}
              </option>
              <option value="deleted" selected={@filter_status == "deleted"}>
                {gettext("Deleted")}
              </option>
            </select>
          </label>
        </div>
      </div>

      <button type="button" phx-click="clear_filters" class="btn btn-ghost btn-sm w-full">
        {gettext("Clear")}
      </button>
    </.form>
  </div>

  <%!-- Bulk Actions --%>
  <%!-- Selection now lives client-side (BulkSelectScope hook), so the server
       can't know the count at initial render — the bar always renders and
       starts hidden via inline style + data-bulk-show, which the hook flips
       once something's selected. --%>
  <div
    class="flex gap-2 mb-4 items-center"
    data-bulk-show="has-selection"
    style="display: none;"
  >
    <span
      class="text-sm text-base-content/70"
      data-bulk-text-template={gettext("%{count} selected", count: "%{count}")}
    ></span>
    <button data-bulk-action="bulk_approve" class="btn btn-success btn-xs">
      {gettext("Approve")}
    </button>
    <button data-bulk-action="bulk_hide" class="btn btn-warning btn-xs">
      {gettext("Hide")}
    </button>
    <button
      data-bulk-action="bulk_delete_comments"
      class="btn btn-error btn-xs"
      data-confirm={gettext("Delete selected comments?")}
    >
      {gettext("Delete")}
    </button>
  </div>

  <%!-- Comments Table --%>
  <%= if length(@comments) > 0 do %>
    <.bulk_select_scope id="comments-bulk" total_count={length(@comments)}>
      <.table_default
        id="comments-table"
        variant="zebra"
        size="sm"
        class="w-full"
        toggleable={true}
        items={@comments}
        card_fields={
          fn comment ->
            # Resource/Display are shown by the chip in the card header instead.
            [
              %{
                label: gettext("Author"),
                value: if(comment.user, do: comment.user.email, else: gettext("Deleted user"))
              },
              %{
                label: gettext("Date"),
                value: Calendar.strftime(comment.inserted_at, "%b %d, %Y")
              },
              %{label: gettext("Status"), value: status_badge_value(comment.status)}
            ]
          end
        }
      >
        <%!-- Toolbar header: the filtered result count (the stats above show the
             unfiltered totals) shares the row with the grid/list view toggle, so
             the toggle no longer sits alone on a row of its own. --%>
        <:toolbar_title>
          <span class="text-sm font-medium text-base-content/70">
            {ngettext("%{count} comment", "%{count} comments", @total)}
          </span>
        </:toolbar_title>
        <%!-- Card header renders the content as markdown (like the table cell),
             so the grid view shows formatting instead of raw markdown. --%>
        <:card_header :let={comment}>
          <%!-- Resource chip first, so the card shows what the comment is on (and
               links to it) — the same clickable thumbnail chip as the table. --%>
          <div class="mb-1.5">
            <.resource_chip comment={comment} resource_context={@resource_context} />
          </div>
          <.reply_indicator comment={comment} />
          <.comment_content_preview comment={comment} />
        </:card_header>
        <:card_actions :let={comment}>
          <%!-- Distinct id from the table menu: both views are in the DOM. --%>
          <.comment_actions_menu comment={comment} id={"comment-menu-card-#{comment.uuid}"} />
        </:card_actions>

        <.table_default_header>
          <.table_default_row hover={false}>
            <.bulk_select_header_cell id="comments-select-all" aria_label={gettext("Select all comments")} />
            <.table_default_header_cell>{gettext("Content")}</.table_default_header_cell>
            <.table_default_header_cell>{gettext("Author")}</.table_default_header_cell>
            <.table_default_header_cell>{gettext("Resource")}</.table_default_header_cell>
            <.table_default_header_cell>{gettext("Date")}</.table_default_header_cell>
            <.table_default_header_cell>{gettext("Status")}</.table_default_header_cell>
            <.table_default_header_cell>{gettext("Actions")}</.table_default_header_cell>
          </.table_default_row>
        </.table_default_header>

        <.table_default_body>
          <%= for comment <- @comments do %>
            <.table_default_row>
              <.bulk_select_cell value={comment.uuid} />
              <.table_default_cell class="max-w-xs">
                <.reply_indicator comment={comment} />
                <.comment_content_preview comment={comment} />
              </.table_default_cell>
              <.table_default_cell class="text-sm">
                <%= if comment.user do %>
                  {comment.user.email}
                <% else %>
                  <span class="text-base-content/50">{gettext("Deleted user")}</span>
                <% end %>
              </.table_default_cell>
              <.table_default_cell>
                <.resource_chip comment={comment} resource_context={@resource_context} />
              </.table_default_cell>
              <.table_default_cell class="text-sm text-base-content/70">
                {Calendar.strftime(comment.inserted_at, "%b %d, %Y")}
              </.table_default_cell>
              <.table_default_cell>
                <span class={status_badge_class(comment.status)}>
                  {comment.status}
                </span>
              </.table_default_cell>
              <.table_default_cell>
                <.comment_actions_menu comment={comment} id={"comment-menu-#{comment.uuid}"} />
              </.table_default_cell>
            </.table_default_row>
          <% end %>
        </.table_default_body>
      </.table_default>
    </.bulk_select_scope>
  <% else %>
    <div class="text-center py-12 text-base-content/60">
      <.icon name="hero-chat-bubble-left" class="w-12 h-12 mx-auto mb-2 opacity-50" />
      <p>{gettext("No comments found")}</p>
    </div>
  <% end %>

  <%!-- Pagination --%>
  <%= if @total_pages > 1 do %>
    <div class="flex justify-center mt-6">
      <div class="join">
        <%= for page <- max(1, @page - 2)..min(@total_pages, @page + 2) do %>
          <.link
            patch={
              Routes.path("/admin/comments?#{build_url_params(assigns, %{"page" => to_string(page)})}")
            }
            class={["join-item btn btn-sm", if(page == @page, do: "btn-active", else: "")]}
          >
            {page}
          </.link>
        <% end %>
      </div>
    </div>
  <% end %>

  <%!-- Full-comment modal — opened by clicking a truncated comment in the list.
       Shows the whole comment in formatted prose plus context and the same
       status-aware action menu. --%>
  <%= if @viewing_comment do %>
    <div class="modal modal-open" phx-window-keydown="close_comment" phx-key="Escape">
      <div class="modal-box max-w-2xl">
        <div class="flex items-start justify-between gap-3 mb-3">
          <h3 class="font-bold text-lg">{gettext("Comment")}</h3>
          <div class="flex items-center gap-1">
            <.comment_actions_menu
              comment={@viewing_comment}
              id={"comment-menu-modal-#{@viewing_comment.uuid}"}
            />
            <button
              phx-click="close_comment"
              class="btn btn-sm btn-circle btn-ghost"
              title={gettext("Close")}
            >
              <.icon name="hero-x-mark" class="w-4 h-4" />
            </button>
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-2 mb-3 text-sm text-base-content/70">
          <span>
            {if @viewing_comment.user,
              do: @viewing_comment.user.email,
              else: gettext("Deleted user")}
          </span>
          <span class="text-base-content/30">·</span>
          <span>{Calendar.strftime(@viewing_comment.inserted_at, "%b %d, %Y")}</span>
          <span class={status_badge_class(@viewing_comment.status)}>{@viewing_comment.status}</span>
        </div>

        <div class="mb-3">
          <.resource_chip comment={@viewing_comment} resource_context={@resource_context} />
        </div>

        <div class="rounded-lg bg-base-200 p-4 max-h-[60vh] overflow-y-auto space-y-2">
          <.comment_markdown
            :if={not blank_content?(@viewing_comment.content)}
            content={@viewing_comment.content}
          />
          <%!-- Media-only comments have no text body — render the GIF / list the
               attachments so the modal isn't blank. --%>
          <%= if gif_url = comment_gif_url(@viewing_comment) do %>
            <img src={gif_url} alt="" class="max-h-64 rounded-lg" />
          <% end %>
          <div
            :if={attachment_count(@viewing_comment) > 0}
            class="flex items-center gap-1.5 text-sm text-base-content/70"
          >
            <.icon name="hero-paper-clip" class="w-4 h-4 shrink-0" />
            {ngettext("%{count} attachment", "%{count} attachments",
              attachment_count(@viewing_comment))}
          </div>
        </div>

        <div class="modal-action">
          <button phx-click="close_comment" class="btn btn-ghost">{gettext("Close")}</button>
        </div>
      </div>
      <div class="modal-backdrop" phx-click="close_comment"></div>
    </div>
  <% end %>
</div>
